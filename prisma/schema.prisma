generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reservation {
  id          String   @id @default(cuid())
  fullName    String
  certificateId String?   // 🔥 EKLE

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  action     String
  targetType String?
  targetId   String?
  details    String?

  @@index([createdAt])
  @@index([action])
  @@index([targetType])
  @@index([targetId])
}

model Instructor {
  id        String   @id @default(cuid())
  fullName  String
  title     String?
  createdAt DateTime @default(now())

  certificates Certificate[]

  @@index([createdAt])
}

model Certificate {
  id                 String    @id @default(cuid())
  certificateId      String    @unique
  fullName           String
  program            String?
  qualificationLevel String?
  issueDate          DateTime?
  seaMiles           Int?
  photoUrl           String?
  cardFrontUrl       String?
  cardBackUrl        String?
  qrCodeUrl          String?
  verificationHash   String?   @unique
  status             String    @default("PENDING")

  instructorId String?
  instructor   Instructor? @relation(fields: [instructorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([certificateId])
  @@index([createdAt])
  @@index([instructorId])
  @@index([status])
}

model CharterBoat {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  model       String
  year        Int
  cabins      Int
  guestsLabel String
  location    String
  image       String
  shortNote   String
  description String
  features    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prices       CharterBoatPrice[]
  inquiries    Inquiry[]
  availability CharterAvailability[]
}

model CharterBoatPrice {
  id    String @id @default(cuid())
  month String
  price String

  boatId String
  boat   CharterBoat @relation(fields: [boatId], references: [id], onDelete: Cascade)

  @@unique([boatId, month])
  @@index([boatId])
}

model CharterAvailability {
  id     String      @id @default(cuid())
  boatId String
  boat   CharterBoat @relation(fields: [boatId], references: [id], onDelete: Cascade)

  weekLabel     String
  startDate     DateTime
  endDate       DateTime
  status        String   @default("AVAILABLE")
  inquiryCount  Int      @default(0)
  hasConflict Boolean? @default(false)
  overridePrice String?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inquiries Inquiry[]

  @@unique([boatId, startDate, endDate])
  @@index([boatId])
  @@index([startDate])
  @@index([status])
}

model Inquiry {
  id String @id @default(cuid())

  fullName String
  email    String?
  phone    String?
  message  String?
  notes    String?

  type   String @default("CHARTER")
  status String @default("NEW")

  guestCount           Int?
  routePreference      String?
  skipperRequired      Boolean @default(false)
  charterDurationWeeks Int?

  trainingProgram  String?
  participantCount Int?

  boatId String?
  boat   CharterBoat? @relation(fields: [boatId], references: [id])

  weekId String?
  week   CharterAvailability? @relation(fields: [weekId], references: [id])

  leadScore      Int?
  estimatedValue Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([boatId])
  @@index([weekId])
}
